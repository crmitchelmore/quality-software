{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Software Design Philosophy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "originators",
    "origin",
    "short_description",
    "description",
    "core_tenets",
    "associated_patterns",
    "successfully_applied",
    "references"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 3 },
    "aka": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "originators": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "uniqueItems": true
    },
    "origin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["book", "essay", "paper", "talk", "manifesto", "tradition", "blog"]
        },
        "title": { "type": "string" },
        "year": { "type": "integer" },
        "era": { "type": "string" }
      }
    },
    "short_description": { "type": "string", "minLength": 10, "maxLength": 320 },
    "description": { "type": "string", "minLength": 50 },
    "core_tenets": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "key_ideas": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "explanation"],
        "properties": {
          "name": { "type": "string" },
          "explanation": { "type": "string" }
        }
      }
    },
    "in_practice": { "type": "string" },
    "complements": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "tensions_with": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["philosophy", "reason"],
        "properties": {
          "philosophy": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "associated_patterns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pattern", "reason"],
        "properties": {
          "pattern": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "at_odds_patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pattern", "reason"],
        "properties": {
          "pattern": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "successfully_applied": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["where", "what", "evidence_strength", "source"],
        "properties": {
          "where": { "type": "string" },
          "what": { "type": "string" },
          "evidence_strength": {
            "type": "string",
            "enum": ["primary-source", "secondary-source", "inferred"]
          },
          "source": {
            "type": "object",
            "additionalProperties": false,
            "required": ["title"],
            "properties": {
              "title": { "type": "string" },
              "url": { "type": "string" },
              "year": { "type": "integer" }
            }
          }
        }
      }
    },
    "best_for": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "criticisms": { "type": "array", "items": { "type": "string" } },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title"],
        "properties": {
          "title": { "type": "string" },
          "author": { "type": "string" },
          "year": { "type": "integer" },
          "url": { "type": "string" }
        }
      }
    }
  }
}
